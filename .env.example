# ─────────────────────────────────────────────────────────────────────────────
# RAG AI Chatbot — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
#
# Only the keys for your CHOSEN provider are required.
# For example, if you use Gemini + HuggingFace, you only need GOOGLE_API_KEY.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ────────────────────────────────────────────────────────────
# Options: "openai" | "gemini"
LLM_PROVIDER=gemini

# ── OpenAI (required if LLM_PROVIDER=openai or EMBEDDING_PROVIDER=openai) ──
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── Google Gemini (required if LLM_PROVIDER=gemini) ────────────────────────
GOOGLE_API_KEY=your-google-api-key-here

# ── Embedding Provider ──────────────────────────────────────────────────────
# Options: "openai" | "huggingface"
# huggingface runs locally (free, no API key needed)
EMBEDDING_PROVIDER=openai

# ── Vector Store ────────────────────────────────────────────────────────────
# Options: "faiss" | "chroma"
VECTOR_STORE_TYPE=faiss
